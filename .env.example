PIMM_BASE_URL=https://openrouter.ai/api/v1
PIMM_API_KEY=your_api_key_here

# Defaults to openai-response API response format.
PIMM_API_TYPE=openai-completions
PIMM_PROVIDER_NAME=custom-provider-name
PIMM_METADATA_DATA_URL=https://yourdomain.com/path/to/models-data.json

# Defaults to 3600 seconds.
PIMM_CACHE_TTL_SECONDS=3600
# Defaults to $XDG_CACHE_HOME/pi-models-metadata, or ~/.cache/pi-models-metadata.
PIMM_CACHE_DIR=/path/to/cache
# Set to true to bypass cache reads while still refreshing cache after requests.
PIMM_SKIP_CACHE=false
